{
  "name": "cc-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev":             "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "build":           "vite build",
    "lint":            "eslint .",
    "preview":         "vite preview",

    "build:main":      "esbuild electron/main.ts --bundle --platform=node --target=node20 --format=cjs --packages=external --inject:electron/import-meta-url.js --define:import.meta.url=__importMetaUrl --outfile=dist-electron/main.cjs",
    "build:preload":   "esbuild electron/preload.ts --bundle --platform=node --target=node20 --format=cjs --packages=external --outfile=dist-electron/preload.cjs",

    "electron:dev":    "concurrently \"vite\" \"tsx watch server/index.ts\" \"wait-on http://localhost:2002 && npm run build:main && npm run build:preload && electron .\"",
    "electron:build":  "npm run build && npm run build:main && npm run build:preload && npm run electron:rebuild && electron-builder",
    "electron:rebuild":"electron-rebuild -f -o node-pty"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1043.0",
    "@supabase/supabase-js": "^2.105.3",
    "@types/ws": "^8.18.1",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.14.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tweakcc": "^4.0.11",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  }
}
